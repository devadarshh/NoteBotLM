# =============================================================================
# AUTHENTICATION
# =============================================================================
# NextAuth Secret - Generate with: npx auth secret
# https://next-auth.js.org/configuration/options#secret
AUTH_SECRET=""

# NextAuth URL (required for production, e.g., https://your-app.vercel.app)
NEXTAUTH_URL=""

# =============================================================================
# DATABASE - SUPABASE POSTGRESQL
# =============================================================================
# Connection pooling URL (used in production)
# Format: postgresql://postgres:password@host:port/database
DATABASE_URL=""

# Direct connection URL (used for migrations)
DIRECT_URL=""

# =============================================================================
# GOOGLE OAUTH & AI
# =============================================================================
# Get from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_GENERATIVE_AI_API_KEY=""

# =============================================================================
# SUPABASE STORAGE & AUTH
# =============================================================================
# Get from: https://supabase.com/dashboard/project/_/settings/api
# Public Supabase URL (exposed to client)
NEXT_PUBLIC_SUPABASE_URL=""

# Supabase Anonymous Key (public, safe to expose)
SUPABASE_KEY=""

# Supabase Service Role Key (secret, server-side only)
SUPABASE_SERVICE_ROLE_KEY=""

# Alternative naming (used in some parts of the code)
SUPABASE_URL=""

# Client-side anonymous key
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# =============================================================================
# REDIS / VALKEY (FOR BULLMQ JOB QUEUE)
# =============================================================================
# Local Redis configuration (for development)
REDIS_HOST="localhost"
REDIS_PORT="6379"

# Upstash Redis (for production on Vercel)
# Get from: https://console.upstash.com/
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# =============================================================================
# QDRANT (VECTOR DATABASE)
# =============================================================================
# Local: http://localhost:6333
# Cloud: https://your-cluster.cloud.qdrant.io:6333
QDRANT_URL="http://localhost:6333"

# Optional API key for cloud Qdrant
# QDRANT_API_KEY=""

# =============================================================================
# HUGGINGFACE (FOR EMBEDDINGS)
# =============================================================================
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=""

# =============================================================================
# ENVIRONMENT & BUILD FLAGS
# =============================================================================
NODE_ENV="development"

# Skip environment validation (useful for Docker builds)
# SKIP_ENV_VALIDATION="1"

# Disable Next.js telemetry
# NEXT_TELEMETRY_DISABLED="1"

# Vercel deployment URL (auto-set by Vercel, don't set manually)
# VERCEL_URL=""

